        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Cpath fill='{{ self::ehex(c=flavor.colors.red) }}' d='M0 0h512v512H0z'/%3E%3Cpath fill='{{ self::ehex(c=flavor.colors.blue) }}' d='M0 0h256v256H0z'/%3E%3Cpath fill='{{ self::ehex(c=if(cond=flavor.dark, t=flavor.colors.text, f=flavor.colors.base)) }}' d='M211.478 128l-34.11 16.046 18.164 33.034-37.039-7.086-4.694 37.417L128 179.891l-25.799 27.52-4.693-37.417-37.041 7.085 18.164-33.036L44.522 128l34.11-16.045-18.165-33.034 37.04 7.085 4.694-37.417L128 76.109l25.799-27.52 4.694 37.417 37.04-7.085-18.164 33.036z'/%3E%3Ccircle cx='128' cy='128' r='51.989' fill='{{ self::ehex(c=flavor.colors.blue) }}'/%3E%3Cpath d='M128 155.703c-15.274 0-27.703-12.427-27.703-27.703s12.427-27.703 27.703-27.703c15.274 0 27.703 12.427 27.703 27.703S143.274 155.703 128 155.703z' fill='{{ self::ehex(c=if(cond=flavor.dark, t=flavor.colors.text, f=flavor.colors.base)) }}'/%3E%3C/svg%3E") !important;
