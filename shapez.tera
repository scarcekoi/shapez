      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] img[src="res/logo.png"] {
        content: url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}")
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] {
        background-color: #{{ flavor.colors.mantle.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] ::-webkit-scrollbar-thumb {
        background-color: #{{ flavor.colors.text.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] a {
        color: #{{ flavor.colors.text.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] body {
        color: #{{ flavor.colors.text.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox {
        background-color: #{{ flavor.colors.surface0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox:hover {
        background-color: #{{ flavor.colors.surface1.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox .knob {
        background-color: #{{ flavor.colors.text.hex }};
        transition:
          margin-left .4s ease-in-out,
          background-color .3s ease-in-out !important;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox.checked {
        background-color: #{{ accent.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox.checked:hover {
        background-color: #{{ accent | sub(lightness=5) | hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .checkbox.checked .knob {
        background-color: #{{ flavor.colors.base.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] input.rangeInput::-webkit-slider-runnable-track {
        color: #{{ flavor.colors.crust.hex }};
        background-color: #{{ flavor.colors.crust.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] input.rangeInput::-webkit-slider-thumb {
        box-shadow:inset 0 0 0 calc(10px*var(--ui-scale)) #{{ flavor.colors.surface0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] input.rangeInput:hover::-webkit-slider-thumb {
        box-shadow:inset 0 0 0 calc(10px*var(--ui-scale)) #{{ flavor.colors.surface0 | sub(lightness=5) | hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState {
        background: #{{ if(cond=flavor.dark, t=flavor.colors.base.hex, f=flavor.colors.subtext0.hex) }} 50%/cover !important;
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .footer .footerGrow>a {
        color: #{{ flavor.colors.text.hex }};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .footer .author a img {
      filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(43%) sepia(43%) saturate(515%) hue-rotate(196deg) brightness(49%) contrast(68%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(83%) sepia(29%) saturate(508%) hue-rotate(192deg) brightness(97%) contrast(98%){%- elif flavor.identifier == "macchiato" -%}brightness(0) saturate(100%) invert(73%) sepia(80%) saturate(1008%) hue-rotate(190deg) brightness(120%) contrast(92%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(75%) sepia(82%) saturate(1008%) hue-rotate(189deg) brightness(120%) contrast(90%){%- endif -%};
      }

      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .styledButton {
        color: #{{ flavor.colors.base.hex }};
        background-color: #{{ accent.hex }};
      }

      /* Homescreen main container */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer {
        background-color: #{{ flavor.colors.base.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .savegamesMount .savegames .savegame {
        background-color: #{{ flavor.colors.surface0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .savegamesMount .savegames .savegame button.downloadGame,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .savegamesMount .savegames .savegame button.deleteGame {
        filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(43%) sepia(43%) saturate(515%) hue-rotate(196deg) brightness(49%) contrast(68%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(83%) sepia(29%) saturate(508%) hue-rotate(192deg) brightness(97%) contrast(98%){%- elif flavor.identifier == "macchiato" -%}brightness(0) saturate(100%) invert(73%) sepia(80%) saturate(1008%) hue-rotate(190deg) brightness(120%) contrast(92%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(75%) sepia(82%) saturate(1008%) hue-rotate(189deg) brightness(120%) contrast(90%){%- endif -%};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .savegamesMount .savegames .savegame button.resumeGame {
        background-color: #{{ flavor.colors.surface1.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons .continueButton,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons .playButton {
        color: #{{ flavor.colors.base.hex }};
        background-color: #{{ flavor.colors.green.hex }};
        transition: opacity .12s ease-in-out;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons .continueButton:hover,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons .playButton:hover {
        opacity: 0.9;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .buttons .outer .modsButton {
        background-color: #{{ flavor.colors.pink.hex }} !important;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .steamSso {
        color: #{{ flavor.colors.text.hex }};
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .steamSso .description {
        color: #{{ flavor.colors.text.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .mainContainer .steamSso a.ssoSignIn {
        background: #{{ flavor.colors.crust.hex }} url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") 50%/contain no-repeat;
      }

      /* Homescreen mods container */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .sideContainer .modsOverview {
        background-color: #{{ flavor.colors.base.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .sideContainer .modsOverview h3 {
        color: #{{ flavor.colors.pink.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .sideContainer .modsOverview .header .editMods {
        filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(43%) sepia(43%) saturate(515%) hue-rotate(196deg) brightness(49%) contrast(68%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(83%) sepia(29%) saturate(508%) hue-rotate(192deg) brightness(97%) contrast(98%){%- elif flavor.identifier == "macchiato" -%}brightness(0) saturate(100%) invert(73%) sepia(80%) saturate(1008%) hue-rotate(190deg) brightness(120%) contrast(92%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(75%) sepia(82%) saturate(1008%) hue-rotate(189deg) brightness(120%) contrast(90%){%- endif -%};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .sideContainer .modsOverview .modsList {
        border-color: #{{ flavor.colors.surface0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .sideContainer .modsOverview .mod {
        background-color: #{{ flavor.colors.surface0.hex }};
      }

      /* Dialog (language) */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog.visible {
        animation: f .12s ease-in-out !important;
        -webkit-animation: f .12s ease-in-out !important;

        background: #{{ flavor.colors.surface0 | mod(opacity=0.8) | hex }} !important;
        backdrop-filter: blur(calc(3px * var(--ui-scale))) !important;
        -webkit-backdrop-filter: blur(calc(3px * var(--ui-scale))) !important;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog>.dialogInner {
        background-color: #{{ flavor.colors.base.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog>.dialogInner.optionChooserDialog .optionParent .option {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog>.dialogInner.optionChooserDialog .optionParent .option:hover {
        background-color: #{{ flavor.colors.surface0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog>.dialogInner.optionChooserDialog .optionParent .option.active {
        color: #{{ flavor.colors.base.hex }};
        background-color: #{{ accent.hex }};
      }

      /* Settings */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .gameState.textualState .headerBar .backButton {
      filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(43%) sepia(43%) saturate(515%) hue-rotate(196deg) brightness(49%) contrast(68%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(83%) sepia(29%) saturate(508%) hue-rotate(192deg) brightness(97%) contrast(98%){%- elif flavor.identifier == "macchiato" -%}brightness(0) saturate(100%) invert(73%) sepia(80%) saturate(1008%) hue-rotate(190deg) brightness(120%) contrast(92%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(75%) sepia(82%) saturate(1008%) hue-rotate(189deg) brightness(120%) contrast(90%){%- endif -%};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .gameState.textualState .headerBar h1 {
        color: #{{ flavor.colors.text.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .gameState.textualState>.container>.content {
        background-color: #{{ flavor.colors.base.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.about,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.categoryButton,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.privacy {
        color: #{{ flavor.colors.text.hex }};
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.about.active,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.categoryButton.active,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.privacy.active {
        color: #{{ flavor.colors.base.hex }};
        background-color: #{{ accent.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.manageMods {
        color: #{{ flavor.colors.pink.hex }};
        background-color: #{{ flavor.colors.pink | mix(color=base, amount=0.1) | hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar button.manageMods .newBadge {
        color: #{{ flavor.colors.base.hex }};
        background-color: #{{ flavor.colors.pink.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .categoryContainer .category .setting {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .categoryContainer .category .setting .desc,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .sidebar .versionbar .buildVersion {
        color: #{{ flavor.colors.subtext0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_SettingsState .container .content .categoryContainer .category .setting .value.enum {
        background-color: #{{ flavor.colors.crust.hex }};
        background: #{{ flavor.colors.crust.hex }} url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") calc(100% - 5px*var(--ui-scale)) calc(50% + 1px*var(--ui-scale))/calc(15px*var(--ui-scale)) no-repeat;
      }

      /* Keybindings settings */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .hint {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .category .entry .mapping {
        color: #{{ accent.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .category .entry button.editKeybinding,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .category .entry button.resetKeybinding {
        filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(43%) sepia(43%) saturate(515%) hue-rotate(196deg) brightness(49%) contrast(68%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(83%) sepia(29%) saturate(508%) hue-rotate(192deg) brightness(97%) contrast(98%){%- elif flavor.identifier == "macchiato" -%}brightness(0) saturate(100%) invert(73%) sepia(80%) saturate(1008%) hue-rotate(190deg) brightness(120%) contrast(92%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(75%) sepia(82%) saturate(1008%) hue-rotate(189deg) brightness(120%) contrast(90%){%- endif -%};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .category .entry button.disabled {
        filter: {%- if flavor.identifier == "latte" -%}brightness(0) saturate(100%) invert(94%) sepia(22%) saturate(523%) hue-rotate(179deg) brightness(96%) contrast(76%){%- elif flavor.identifier == "frappe" -%}brightness(0) saturate(100%) invert(11%) sepia(65%) saturate(1032%) hue-rotate(204deg) brightness(86%) contrast(58%){%- elif flavor.identifier == "macchiato" -%}rightness(0) saturate(100%) invert(41%) sepia(39%) saturate(513%) hue-rotate(194deg) brightness(39%) contrast(82%){%- elif flavor.identifier == "mocha" -%}brightness(0) saturate(100%) invert(10%) sepia(79%) saturate(1035%) hue-rotate(212deg) brightness(62%) contrast(70%){%- endif -%};
        opacity: 1 !important;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_KeybindingsState .content .category .entry {
        color: #{{ flavor.colors.subtext0.hex }};
        border-bottom-color: #{{ flavor.colors.surface2.hex }};
      }

      /* Mods settings */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState>.headerBar .openModsFolder {
        background-color: #{{ flavor.colors.pink.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState .modsList .mod {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState .modsStats,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState .modsList .mod .mainInfo .description,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState .modsList .mod .author strong,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_ModsState .modsList .mod .version strong {
        color: #{{ flavor.colors.subtext0.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .gameState.textualState>.container>.content a {
        color: #{{ accent.hex }};
      }
    `)
    {%- endif %}{%- endfor %}
  }
};

const RESOURCES = {
  {%- for _, accent in flavor.colors %}
  {%- if accent.accent %}
  "catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}.json": {
    map: {
      background: "#abc",
      grid: "#ccc",
      gridLineWidth: 1,

      selectionOverlay: "rgba(74, 163, 223, 0.7)",
      selectionOutline: "rgba(74, 163, 223, 0.5)",
      selectionBackground: "rgba(74, 163, 223, 0.2)",

      chunkBorders: "rgba(0, 30, 50, 0.03)",

      directionLock: {
        regular: {
          color: "rgb(74, 237, 134)",
          background: "rgba(74, 237, 134, 0.2)",
        },
        wires: {
          color: "rgb(74, 237, 134)",
          background: "rgba(74, 237, 134, 0.2)",
        },
        error: {
          color: "rgb(255, 137, 137)",
          background: "rgba(255, 137, 137, 0.2)",
        },
      },

      colorBlindPickerTile: "rgba(50, 50, 50, 0.4)",

      resources: {
        shape: "#eaebec",
        red: "#ffbfc1",
        green: "#cbffc4",
        blue: "#bfdaff",
      },

      chunkOverview: {
        empty: "#a6afbb",
        filled: "#c5ccd6",
        beltColor: "#777",
      },

      wires: {
        overlayColor: "rgba(97, 161, 152, 0.75)",
        previewColor: "rgb(97, 161, 152, 0.4)",
        highlightColor: "rgba(72, 137, 255, 1)",
      },

      connectedMiners: {
        overlay: "rgba(40, 50, 60, 0.5)",
        textColor: "#fff",
        textColorCapped: "#ef5072",
        background: "rgba(40, 50, 60, 0.8)",
      },

      zone: {
        borderSolid: "rgba(23, 192, 255, 1)",
        outerColor: "rgba(240, 240, 255, 0.5)",
      },
    },

    items: {
      outline: "#55575a",
      outlineWidth: 0.75,
      circleBackground: "rgba(40, 50, 65, 0.1)",
    },

    shapeTooltip: {
      background: "#dee1ea",
      outline: "#54565e",
    },
  },
  {%- endif %}{%- endfor %}
};
