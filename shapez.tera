---
whiskers:
  version: "^2.9.0"
  matrix:
    - flavor
    - accent
  filename: "themes/catppuccin-{{ flavor.identifier }}.js"
---
{%- macro ehex(c) -%}
%23{{ c.hex }}
{%- endmacro ehex -%}

// @ts-nocheck
const METADATA = {
  website: "https://catppuccin.com",
  author: "Catppuccin Org",
  name: "Catppuccin {{ flavor.name }}",
  version: "1",
  id: "catppuccin-{{ flavor.identifier }}",
  description: "Soothing pastel theme for the high-spirited!",
  minimumGameVersion: ">=1.5.0",
  doesNotAffectSavegame: true,
};

class Mod extends shapez.Mod {
  init() {
    console.log("Initializing Catppuccin Theme");
    {%- for _, accent in flavor.colors %}
    {%- if accent.accent %}
    this.modInterface.registerGameTheme({
      id: "catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}",
      name: "Catppuccin {{ flavor.name }} {{ accent.name }}",
      theme: RESOURCES["catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}.json"],
    })
    this.modInterface.registerCss(`
      /* Homepage circular buttons */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .topButtons .exitAppButton,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .topButtons .languageChoose,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .topButtons .settingsButton,
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .socialLinks>.boxLink .thirdpartyLogo {
        background-color: #{{ flavor.colors.mantle.hex }};
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .topButtons .settingsButton {
        background: #{{ flavor.colors.mantle.hex }} url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") 50%/70% no-repeat;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .topButtons .exitAppButton {
        background: #{{ flavor.colors.mantle.hex }} url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") 50%/70% no-repeat;
        background-size: 56%;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .socialLinks>.boxLink .thirdpartyLogo.githubLogo {
        background: #{{ flavor.colors.mantle.hex }} url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") 50%/70% no-repeat;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .socialLinks>.boxLink .thirdpartyLogo.discordLogo {
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg height='512' width='512' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M433.43 93.222a422.256 422.256 0 00-104.216-32.324 1.582 1.582 0 00-1.675.792c-4.501 8.005-9.486 18.447-12.977 26.655-39.353-5.892-78.505-5.892-117.051 0-3.492-8.39-8.658-18.65-13.179-26.655a1.643 1.643 0 00-1.675-.792c-36.568 6.298-71.562 17.33-104.216 32.324a1.49 1.49 0 00-.686.589c-66.376 99.165-84.56 195.893-75.64 291.421.04.467.303.914.666 1.199 43.793 32.161 86.215 51.685 127.848 64.627a1.656 1.656 0 001.796-.589c9.848-13.449 18.627-27.63 26.154-42.543.444-.873.02-1.91-.888-2.255-13.925-5.282-27.184-11.723-39.939-19.036-1.009-.589-1.09-2.032-.161-2.723a218.562 218.562 0 007.932-6.217 1.585 1.585 0 011.655-.224c83.792 38.257 174.507 38.257 257.31 0a1.578 1.578 0 011.675.203 204.307 204.307 0 007.952 6.237c.928.691.867 2.134-.141 2.723-12.755 7.456-26.014 13.754-39.959 19.016a1.633 1.633 0 00-.867 2.275c7.689 14.892 16.468 29.073 26.134 42.523.404.569 1.13.813 1.796.609 41.835-12.941 84.257-32.466 128.05-64.627a1.64 1.64 0 00.666-1.178c10.676-110.441-17.881-206.376-75.7-291.421a1.297 1.297 0 00-.664-.609zM171.094 327.065c-25.227 0-46.014-23.16-46.014-51.604 0-28.443 20.383-51.604 46.014-51.604 25.831 0 46.417 23.364 46.013 51.604 0 28.444-20.384 51.604-46.013 51.604zm170.127 0c-25.226 0-46.013-23.16-46.013-51.604 0-28.443 20.383-51.604 46.013-51.604 25.832 0 46.417 23.364 46.014 51.604 0 28.444-20.181 51.604-46.014 51.604z' fill='{{ self::ehex(c=flavor.colors.blue) }}'/%3E%3C/svg%3E");
        background-size: 66%;
        background-position: 50% 53%;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .socialLinks>.boxLink .thirdpartyLogo.redditLogo {
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg height='512' viewBox='0 0 24 24' width='512' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M21.325 9.308c-.758 0-1.425.319-1.916.816-1.805-1.268-4.239-2.084-6.936-2.171l1.401-6.406 4.461 1.016c0 1.108.89 2.013 1.982 2.013 1.113 0 2.008-.929 2.008-2.038S21.436.5 20.318.5c-.779 0-1.451.477-1.786 1.129L13.605.521c-.248-.067-.491.113-.557.365L11.51 7.948c-2.676.113-5.084.928-6.895 2.197a2.673 2.673 0 00-1.942-.837c-2.812 0-3.733 3.829-1.158 5.138a5.83 5.83 0 00-.132 1.268c0 4.301 4.775 7.786 10.638 7.786 5.888 0 10.663-3.485 10.663-7.786 0-.431-.045-.883-.156-1.289 2.523-1.314 1.594-5.115-1.203-5.117zm-15.724 5.41c0-1.129.89-2.038 2.008-2.038 1.092 0 1.983.903 1.983 2.038 0 1.109-.89 2.013-1.983 2.013a2.007 2.007 0 01-2.008-2.013zm10.839 4.798c-1.841 1.868-7.036 1.868-8.878 0-.203-.18-.203-.498 0-.703a.48.48 0 01.668 0c1.406 1.463 6.07 1.488 7.537 0a.48.48 0 01.668 0c.207.206.207.524.005.703zm-.041-2.781c-1.092 0-1.982-.903-1.982-2.011 0-1.129.89-2.038 1.982-2.038 1.113 0 2.008.903 2.008 2.038a2.015 2.015 0 01-2.008 2.011z' fill='{{ self::ehex(c=flavor.colors.peach) }}'/%3E%3C/svg%3E");
        background-size: 65%;
      }
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] #state_MainMenuState .socialLinks>.boxLink .thirdpartyLogo.twitterLogo {
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 490.659 490.659'%3E%3Cpath d='M487.84 92.931a10.666 10.666 0 00-12.8-2.261 91.11 91.11 0 01-13.632 4.928 95.99 95.99 0 0016.213-31.211c1.513-5.693-1.876-11.535-7.569-13.048a10.664 10.664 0 00-8.857 1.571 224.2 224.2 0 01-51.328 20.075c-36.787-34.722-92.823-39.05-134.507-10.389-32.109 21.71-49.786 59.232-46.08 97.813A252.588 252.588 0 0152.384 65.134a11.03 11.03 0 00-9.067-3.989 10.664 10.664 0 00-8.533 5.205 103.25 103.25 0 00-11.776 80.149 114.143 114.143 0 0018.539 38.763 56.635 56.635 0 01-10.837-6.933c-4.575-3.711-11.292-3.011-15.004 1.564a10.667 10.667 0 00-2.383 6.714c.634 39.467 22.306 75.588 56.832 94.72a79.104 79.104 0 01-13.739-2.944c-5.641-1.697-11.59 1.5-13.287 7.141a10.675 10.675 0 00.487 7.451 116.412 116.412 0 0080.811 66.133 187.945 187.945 0 01-112.533 23.168 10.517 10.517 0 00-11.371 7.296 10.667 10.667 0 004.907 12.587 319.679 319.679 0 00157.653 44.8 270.763 270.763 0 00149.632-45.76c84.544-56.107 137.237-156.843 129.899-246.976a199.261 199.261 0 0046.379-48.341 10.67 10.67 0 00-1.153-12.951z' fill='{{ self::ehex(c=flavor.colors.sky) }}'/%3E%3C/svg%3E");
        background-size: 60%;
        background-position: 60% 58%;
      }

      /* Dialog close button */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] .ingameDialog>.dialogInner>.title>.closeButton {
        background: url("data:image/png;base64,{%- if flavor.identifier == "latte" -%}{%- elif flavor.identifier == "frappe" -%}{%- elif flavor.identifier == "macchiato" -%}{%- elif flavor.identifier == "mocha" -%}{%- endif -%}") 50%/80% no-repeat;
      }

      /* Language Flags */
      html[data-theme="catppuccin-{{ flavor.identifier }}-{{ accent.identifier }}"] [data-languageicon=en] {
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Cpath d='M400 512H112C50.144 512 0 461.856 0 400V112C0 50.144 50.144 0 112 0h288c61.856 0 112 50.144 112 112v288c0 61.856-50.144 112-112 112z' fill='{{ self::ehex(c=flavor.colors.blue) }}'/%3E%3Cpath d='M512 399.989v-24.587l-79.419-52.033H512v-26.948H296.421V512h26.947V348.46L494.3 460.45a111.414 111.414 0 0013.75-30.896M7.531 440.443a111.728 111.728 0 0010.168 20.007l170.932-111.99V512h26.947V296.421H0v26.948h79.419L0 375.402V400c0 4.306.252 8.553.725 12.733M0 115.807v20.791l79.419 52.034H0v26.947h215.579V0h-26.947v163.54L17.699 51.55A111.378 111.378 0 003.114 85.7m501.207-14.531a111.622 111.622 0 00-10.021-19.62L323.368 163.54V0h-26.947v215.579H512v-26.947h-79.419L512 136.598V112c0-4.46-.269-8.858-.776-13.182' fill='{{ self::ehex(c=if(cond=flavor.dark, t=flavor.colors.text, f=flavor.colors.base)) }}'/%3E%3Cg fill='{{ self::ehex(c=flavor.colors.red) }}'%3E%3Cpath d='M296.421 0h-80.842v215.579H0v80.842h215.579V512h80.842V296.421H512v-80.842H296.421z'/%3E%3Cpath d='M138.395 323.369L.725 412.733a111.28 111.28 0 006.807 27.71l180.359-117.075h-49.496v.001zm206.07 0l163.586 106.186A112.142 112.142 0 00512 400v-.011l-118.039-76.621-49.496.001zM161.684 188.632L3.114 85.7A112.234 112.234 0 000 112v3.807l112.188 72.825h49.496zm211.179 0l138.36-89.814a111.284 111.284 0 00-6.902-27.648L323.368 188.632h49.495z'/%3E%3C/g%3E%3C/svg%3E") !important;
      }
